rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Pseudonym Directory Rules
    match /pseudonyms/{username} {
      allow read: if request.auth != null;
      allow create: if request.auth != null 
                    && request.resource.data.keys().hasAll([
                        'username',
                        'displayName',
                        'uid',
                        'identityPublicKey',
                        'createdAt'
                    ])
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.username == username
                    && request.resource.data.username is string
                    && request.resource.data.displayName is string
                    && request.resource.data.identityPublicKey is string
                    && username.size() >= 3
                    && username.size() <= 20
                    && username.matches('^[a-z][a-z0-9_]*[a-z0-9]$')
                    && !username.matches('.*__.*')
                    && !(username in ['admin', 'administrator', 'moderator', 'support', 'system', 'root', 'memovault']);
      allow update: if request.auth != null 
                    && request.resource.data.username == resource.data.username
                    && request.resource.data.identityPublicKey == resource.data.identityPublicKey
                    && (request.auth.uid == resource.data.uid 
                        || (request.resource.data.uid == request.auth.uid
                            && get(/databases/$(database)/documents/prekey_bundles/$(request.auth.uid)).data.identityPublicKey == resource.data.identityPublicKey));
      allow delete: if false;
    }

    // Prekey Bundles Rules
    match /prekey_bundles/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null 
                    && (request.auth.uid == userId 
                        || (request.resource.data.uid == resource.data.uid
                            && request.resource.data.identityPublicKey == resource.data.identityPublicKey
                            && request.resource.data.signedPrekeyId == resource.data.signedPrekeyId
                            && request.resource.data.signedPrekeyPublic == resource.data.signedPrekeyPublic
                            && request.resource.data.signedPrekeySignature == resource.data.signedPrekeySignature
                            && request.resource.data.kyberPrekeyId == resource.data.kyberPrekeyId
                            && request.resource.data.kyberPrekeyPublic == resource.data.kyberPrekeyPublic
                            && request.resource.data.kyberPrekeySignature == resource.data.kyberPrekeySignature));
      allow delete: if false;
    }

    // Sync Queues Rules
    match /sync_queues/{userId}/messages/{messageId} {
      allow read, delete: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
    }

    // Presence Rules
    match /presence/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Typing Rules
    match /typing/{conversationId}/users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Read Receipts Rules
    match /receipts/{receiptId} {
      allow read, write: if request.auth != null;
    }

    // Compliance collection (readonly for authenticated clients)
    match /compliance/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
